venv/
env/
.venv/
ENV/


# Environment variables
.env
.env.*
*.env


# VS Code & IDE settings
.vscode/
.idea/
*.iml


# Jupyter Notebook checkpoints
.ipynb_checkpoints/


# OS generated files
.DS_Store
Thumbs.db
desktop.ini


